  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "npm run lint && npm run build && npm run server:install && npm run prisma:generate && npm run server:build",
    "server:install": "npm --prefix server install",
    "server:dev": "npm --prefix server run dev",
    "server:build": "npm --prefix server run build",
    "server:start": "npm --prefix server run start",
    "prisma:generate": "npm --prefix server run prisma:generate",
    "prisma:studio": "npm --prefix server run prisma:studio",
    "full:install": "npm install && npm run server:install",
    "full:dev": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "kill:3001": "kill-port 3001",
    "kill:5173": "kill-port 5173",
    "kill:5174": "kill-port 5174",
    "kill:all": "npm run kill:3001 && npm run kill:5173 && npm run kill:5174",
    "restart": "npm run kill:all && npm run full:dev"
  },
  "dependencies": {
    "@msgpack/msgpack": "^2.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
