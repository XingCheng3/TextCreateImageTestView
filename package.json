{
  "name": "baseconnectpostgresql",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:install": "cd server && npm install",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "server:start": "cd server && npm start",
    "prisma:generate": "cd server && npm run prisma:generate",
    "prisma:studio": "cd server && npm run prisma:studio",
    "full:install": "npm install && npm run server:install",
    "full:dev": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "postinstall": "npm run server:install && npm run prisma:generate",
    "kill:3001": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 3001",
    "kill:5173": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 5173",
    "kill:5174": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 5174",
    "kill:all": "npm run kill:3001 && npm run kill:5173 && npm run kill:5174",
    "restart": "npm run kill:all && npm run full:dev"
  },
  "dependencies": {
    "@msgpack/msgpack": "^2.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.62.11",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "npm:rolldown-vite@7.1.14"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.14"
  }
}
